#!/bin/bash -e

use_bee=false
use_hornet=false
use_agent_sandbox=false
use_dev_sandbox=false
update_secrets=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --bee)
            use_bee=true
            shift
            ;;
        --hornet)
            use_hornet=true
            shift
            ;;
        --agent-sandbox)
            use_agent_sandbox=true
            shift
            ;;
        --dev-sandbox)
            use_dev_sandbox=true
            shift
            ;;
        --update-secrets)
            update_secrets=true
            shift
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

if [[ "$update_secrets" == true ]]; then
    if [[ "$use_bee" == true ]]; then
        update_secrets --bee
    else
        update_secrets
    fi
fi

current_host="$(hostname)"

if [[ "$use_bee" == true ]]; then
    if [[ "$current_host" == "bee" ]]; then
        sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#bee"
    else
        nix run nixpkgs#nixos-rebuild -- --fast --target-host bee --build-host bee --flake "$HOME/Developer/dotfiles-priv#bee" --use-remote-sudo switch
    fi
elif [[ "$use_hornet" == true ]]; then
    if [[ "$current_host" == "hornet" ]]; then
        sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#hornet"
    else
        nix run nixpkgs#nixos-rebuild -- --fast --target-host hornet --build-host bee --flake "$HOME/Developer/dotfiles-priv#hornet" --use-remote-sudo switch
    fi
elif [[ "$use_agent_sandbox" == true ]]; then
    if [[ "$current_host" == "agent-sandbox" ]]; then
        TOKEN=$(github-app-token)
        sudo nixos-rebuild switch \
            --refresh \
            --impure \
            --flake "$HOME/Developer/dotfiles-priv#agent-sandbox" \
            --option access-tokens "github.com=$TOKEN" \
            "$@"
    else
        nix run nixpkgs#nixos-rebuild -- --fast --target-host gabriel@agent-sandbox --build-host bee --flake "$HOME/Developer/dotfiles-priv#agent-sandbox" --use-remote-sudo switch
    fi
elif [[ "$use_dev_sandbox" == true ]]; then
    if [[ "$current_host" == "dev-sandbox" ]]; then
        sudo nixos-rebuild switch --impure --flake "$HOME/Developer/dotfiles-priv#dev-sandbox"
    else
        limactl shell dev-sandbox -- bash -c "sudo nixos-rebuild switch --impure --flake \$HOME/Developer/dotfiles-priv#dev-sandbox"
    fi
else
    case "$current_host" in
        bee)
            sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#bee"
            ;;
        hornet)
            sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#hornet"
            ;;
        agent-sandbox)
            TOKEN=$(github-app-token)
            sudo nixos-rebuild switch \
                --refresh \
                --impure \
                --flake "$HOME/Developer/dotfiles-priv#agent-sandbox" \
                --option access-tokens "github.com=$TOKEN" \
                "$@"
            ;;
        dev-sandbox)
            sudo nixos-rebuild switch --impure --flake "$HOME/Developer/dotfiles-priv#dev-sandbox"
            ;;
        *)
            sudo darwin-rebuild switch --flake "$HOME/Developer/dotfiles-priv/" --override-input public path:"$HOME/Developer/dotfiles"
            ;;
    esac
fi
