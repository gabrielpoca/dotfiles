#!/bin/bash -e

use_bee=false
use_hornet=false
use_dev_sandbox=false
use_mantis=false
update_secrets=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --bee)
            use_bee=true
            shift
            ;;
        --hornet)
            use_hornet=true
            shift
            ;;
        --dev-sandbox)
            use_dev_sandbox=true
            shift
            ;;
        --mantis)
            use_mantis=true
            shift
            ;;
        --update-secrets)
            update_secrets=true
            shift
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

if [[ "$update_secrets" == true ]]; then
    if [[ "$use_bee" == true ]]; then
        update_secrets --bee
    else
        update_secrets
    fi
fi

current_host="$(hostname)"
public_override=()
if [[ -d "$HOME/Developer/dotfiles" ]]; then
    public_override=(--override-input public "path:$HOME/Developer/dotfiles")
fi

if [[ "$use_bee" == true ]]; then
    if [[ "$current_host" == "bee" ]]; then
        sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#bee"
    else
        nix run nixpkgs#nixos-rebuild -- --fast --target-host bee --build-host bee --flake "$HOME/Developer/dotfiles-priv#bee" --use-remote-sudo switch
    fi
elif [[ "$use_hornet" == true ]]; then
    if [[ "$current_host" == "hornet" ]]; then
        sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#hornet"
    else
        nix run nixpkgs#nixos-rebuild -- --fast --target-host hornet --build-host hornet --flake "$HOME/Developer/dotfiles-priv#hornet" --use-remote-sudo switch
    fi
elif [[ "$use_dev_sandbox" == true ]]; then
    if [[ "$current_host" == "dev-sandbox" ]]; then
        sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#dev-sandbox" "${public_override[@]}"
    else
        limactl shell dev-sandbox -- bash -lc 'public_override=(); if [[ -d "$HOME/Developer/dotfiles" ]]; then public_override=(--override-input public "path:$HOME/Developer/dotfiles"); fi; sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#dev-sandbox" "${public_override[@]}"'
    fi
elif [[ "$use_mantis" == true ]]; then
    if [[ "$current_host" == "mantis" ]]; then
        sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#mantis"
    else
        nix run nixpkgs#nixos-rebuild -- --fast --target-host mantis --build-host mantis --flake "$HOME/Developer/dotfiles-priv#mantis" --use-remote-sudo switch
    fi
else
    case "$current_host" in
        bee)
            sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#bee"
            ;;
        hornet)
            sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#hornet"
            ;;
        dev-sandbox)
            sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#dev-sandbox" "${public_override[@]}"
            ;;
        mantis)
            sudo nixos-rebuild switch --flake "$HOME/Developer/dotfiles-priv#mantis"
            ;;
        *)
            sudo darwin-rebuild switch --flake "$HOME/Developer/dotfiles-priv/" "${public_override[@]}"
            ;;
    esac
fi
